<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Colorado Bankruptcy Intelligence — District Trends 2026</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --green-deep:#254E38;--green-mid:#275C3E;--green-sage:#8AA88F;
  --gold:#D6AE47;--gold-light:#EDD98A;--cream:#FAF9F6;--cream-warm:#F7F3E8;
  --charcoal:#3E403E;--gray-light:#E8E5DE;--gray-mid:#9A9A98;--white:#FFFFFF;
  --font-serif:Georgia,'Times New Roman',serif;
  --font-sans:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
}
body{background:var(--cream);color:var(--charcoal);font-family:var(--font-sans);font-size:14px;line-height:1.5}

/* MASTHEAD */
.masthead{background:var(--green-deep);border-bottom:3px solid var(--gold)}
.masthead-inner{max-width:1140px;margin:0 auto;padding:28px 32px 22px;display:flex;align-items:flex-end;justify-content:space-between;gap:20px;flex-wrap:wrap}
.masthead-eyebrow{font-size:11px;color:var(--green-sage);letter-spacing:.12em;text-transform:uppercase;font-weight:700;margin-bottom:5px}
.masthead-title{font-family:var(--font-serif);font-size:34px;font-weight:700;color:var(--cream);letter-spacing:-.3px;line-height:1.1}
.masthead-title span{color:var(--gold)}
.masthead-tagline{font-size:11px;color:var(--green-sage);letter-spacing:.1em;text-transform:uppercase;margin-top:5px;font-weight:600}
.masthead-right{text-align:right}
.masthead-issue{font-family:var(--font-serif);font-size:13px;color:var(--gold-light);margin-bottom:3px}
.masthead-credit{font-size:11px;color:var(--green-sage);margin-top:4px}

/* PAGE */
.page{max-width:1140px;margin:0 auto;padding:32px 32px 60px}

/* SECTION HEADERS */
.sh{display:flex;align-items:center;gap:10px;margin:36px 0 16px;padding-bottom:8px;border-bottom:2px solid var(--green-deep)}
.sh:first-child{margin-top:0}
.sh h2{font-family:var(--font-serif);font-size:18px;color:var(--green-deep);font-weight:700}
.pill{background:var(--gold);color:var(--green-deep);font-size:10px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;padding:2px 8px;border-radius:20px}
.pill.green{background:var(--green-deep);color:var(--gold)}

/* STAT CARDS */
.stat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:12px;margin-bottom:8px}
.stat-card{background:var(--white);border:1px solid var(--gray-light);border-top:3px solid var(--green-deep);border-radius:4px;padding:14px 16px}
.stat-card.dark{background:var(--green-deep);border-top-color:var(--gold)}
.stat-card .lbl{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--green-sage);margin-bottom:6px}
.stat-card .num{font-family:var(--font-serif);font-size:28px;font-weight:700;color:var(--green-deep);line-height:1}
.stat-card.dark .num{color:var(--gold)}
.stat-card .sub{font-size:11px;color:var(--gray-mid);margin-top:3px}
.stat-card.dark .sub{color:var(--green-sage)}
.stat-card .trend-badge{display:inline-block;font-size:10px;font-weight:700;padding:1px 6px;border-radius:10px;margin-top:4px}
.trend-up{background:#e6f4ec;color:#1a7a3c}
.trend-dn{background:#fdecea;color:#c0392b}
.trend-fl{background:#f0f0f0;color:#666}

/* SVG TREND CHART */
.chart-wrap{background:var(--white);border:1px solid var(--gray-light);border-radius:4px;padding:20px 24px 16px;overflow:hidden}
.chart-wrap svg{width:100%;height:auto;display:block}

/* MOM CALLOUT ROW */
.mom-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:8px}
.mom-card{background:var(--white);border:1px solid var(--gray-light);border-radius:4px;padding:12px 16px;display:flex;align-items:center;gap:12px}
.mom-icon{font-size:24px;line-height:1}
.mom-label{font-size:11px;color:var(--gray-mid);text-transform:uppercase;letter-spacing:.07em;font-weight:700;margin-bottom:2px}
.mom-val{font-family:var(--font-serif);font-size:20px;font-weight:700;color:var(--green-deep)}
.mom-chg{font-size:12px;font-weight:700}

/* TABS */
.tabs{display:flex;gap:0;border-bottom:2px solid var(--green-deep);margin-bottom:0}
.tab{padding:9px 20px;font-size:12px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;cursor:pointer;border:1px solid var(--gray-light);border-bottom:none;background:var(--cream-warm);color:var(--gray-mid);border-radius:4px 4px 0 0;margin-right:3px;transition:all .15s}
.tab.active{background:var(--green-deep);color:var(--cream);border-color:var(--green-deep)}
.tab-panel{display:none}.tab-panel.active{display:block}

/* TABLE CONTROLS */
.tbl-controls{display:flex;gap:8px;align-items:center;margin:14px 0 10px;flex-wrap:wrap;padding:14px;background:var(--cream-warm);border:1px solid var(--gray-light);border-radius:4px 4px 0 0}
.search-box{padding:7px 12px;font-size:13px;font-family:var(--font-sans);border:1px solid var(--gray-light);border-radius:4px;outline:none;background:var(--white);width:220px;color:var(--charcoal)}
.search-box:focus{border-color:var(--green-sage)}
.filter-btn{padding:6px 11px;font-size:11px;font-family:var(--font-sans);font-weight:700;letter-spacing:.05em;border:1px solid var(--gray-light);border-radius:4px;cursor:pointer;background:var(--white);color:var(--charcoal);transition:all .15s}
.filter-btn.active{background:var(--green-deep);border-color:var(--green-deep);color:var(--cream)}
.result-count{font-size:11px;color:var(--gray-mid);margin-left:auto}

/* TABLE */
.tbl-wrap{overflow-x:auto;border:1px solid var(--gray-light);border-top:none;border-radius:0 0 4px 4px;box-shadow:0 1px 4px rgba(0,0,0,.05)}
table{width:100%;border-collapse:collapse;background:var(--white)}
th{background:var(--green-deep);color:var(--cream);font-size:10px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;padding:10px 14px;cursor:pointer;user-select:none;white-space:nowrap;border-right:1px solid rgba(255,255,255,.08);text-align:center}
th.th-l{text-align:left}
th:last-child{border-right:none}
th:hover{background:var(--green-mid)}
.arr{opacity:.35;font-size:9px;margin-left:3px}
.arr.on{opacity:1}
tbody tr:nth-child(even){background:#F9F8F5}
tbody tr:hover{background:rgba(138,168,143,.12)}
td{padding:8px 14px;border-bottom:1px solid var(--gray-light);font-size:13px;color:var(--charcoal);text-align:center}
td.td-l{text-align:left}
td.td-zero{color:#ccc}
td.td-tot{font-weight:700;color:var(--green-deep);background:rgba(214,174,71,.06)}
tr.tr-foot td{background:var(--green-deep);color:var(--gold);font-weight:700;font-size:13px;border-bottom:none;text-align:center}
tr.tr-foot td:first-child{text-align:left;color:var(--cream)}

/* AP CARDS */


/* MONTHLY DETAIL TABLE */
.monthly-tbl{width:100%;border-collapse:collapse;background:var(--white)}
.monthly-tbl th{background:var(--green-deep);color:var(--cream);font-size:11px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;padding:10px 16px;text-align:center}
.monthly-tbl th:first-child{text-align:left}
.monthly-tbl td{padding:9px 16px;border-bottom:1px solid var(--gray-light);font-size:13px;text-align:center;color:var(--charcoal)}
.monthly-tbl td:first-child{text-align:left;font-weight:600}
.monthly-tbl tr:last-child td{background:var(--cream-warm);font-weight:700;color:var(--green-deep);border-bottom:none}
.chg-up{color:#1a7a3c;font-weight:700}
.chg-dn{color:#c0392b;font-weight:700}

/* FOOTER */
.footer{border-top:1px solid var(--gray-light);margin-top:48px;padding-top:20px;display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:16px}
.footer-brand{font-size:12px;color:var(--gray-mid)}
.footer-brand strong{color:var(--green-deep)}
.footer-note{font-size:11px;color:var(--gray-mid);text-align:right;max-width:400px}

@media(max-width:680px){
  .masthead-inner{padding:20px 16px;flex-direction:column;align-items:flex-start}
  .masthead-right{text-align:left}
  .masthead-title{font-size:26px}
  .page{padding:20px 16px 40px}
  .search-box{width:100%}
}
</style>
<style>
/* ── Intelligence-specific ── */
.ind-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px;margin-bottom:16px}
.ind-card{background:var(--white);border:1px solid var(--gray-light);border-radius:4px;padding:14px 16px;position:relative;overflow:hidden}
.ind-card .ind-label{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--green-sage);margin-bottom:2px}
.ind-card .ind-val{font-size:28px;font-weight:700;color:var(--green-deep);font-family:var(--font-serif);line-height:1.1}
.ind-card .ind-sub{font-size:11px;color:var(--gray-mid);margin-top:3px}
.ind-card .ind-signal{font-size:12px;font-weight:700;margin-top:5px}
.ind-card .ind-context{font-size:11px;color:var(--charcoal);margin-top:5px;line-height:1.4;border-top:1px solid var(--gray-light);padding-top:6px}
.ind-card .ind-source{font-size:10px;color:#bbb;margin-top:4px;font-family:monospace}
.ind-card.alarm{border-top:3px solid #c0392b}
.ind-card.warning{border-top:3px solid #e67e22}
.ind-card.watch{border-top:3px solid var(--gold)}
.ind-card.normal{border-top:3px solid var(--green-sage)}
.ind-card.crisis{border-top:3px solid #7B5EA7}

.insight-box{background:var(--cream-warm);border:1px solid var(--gray-light);border-left:4px solid var(--gold);border-radius:4px;padding:16px 20px;margin-bottom:16px}
.insight-box .insight-title{font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--green-deep);margin-bottom:6px}
.insight-box p{font-size:13px;color:var(--charcoal);line-height:1.65;margin:0}

/* chart selector */
.chart-selector-wrap{background:var(--cream-warm);border:1px solid var(--gray-light);border-radius:4px 4px 0 0;padding:14px 20px;display:flex;align-items:center;gap:12px;flex-wrap:wrap}
.chart-selector-wrap label{font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--green-sage);white-space:nowrap}
.chart-select{padding:7px 12px;font-size:13px;font-family:var(--font-sans);border:1px solid var(--gray-light);border-radius:4px;outline:none;background:var(--white);color:var(--charcoal);cursor:pointer;min-width:300px}
.chart-insight-panel{background:var(--white);border:1px solid var(--gray-light);border-top:none;padding:14px 20px 10px}
.chart-insight-panel .ci-title{font-size:14px;font-weight:700;color:var(--green-deep);margin-bottom:4px}
.chart-insight-panel .ci-body{font-size:12px;color:var(--charcoal);line-height:1.6}
.chart-insight-panel .ci-source{font-size:10px;color:#bbb;margin-top:6px;font-family:monospace}
.chart-canvas-wrap{border:1px solid var(--gray-light);border-top:none;border-radius:0 0 4px 4px;padding:20px 20px 14px;background:var(--white)}
.sup-note{font-size:11px;color:var(--gray-mid);font-style:italic;margin-top:6px}
.source-note{font-size:10px;color:#aaa;margin-top:6px;font-family:monospace}
</style>
</head>
<body>

<div class="masthead">
  <div class="masthead-inner">
    <div>
      <div class="masthead-eyebrow">District of Colorado &nbsp;·&nbsp; U.S. Bankruptcy Court</div>
      <div class="masthead-title">Colorado <span>Bankruptcy</span> Intelligence</div>
      <div class="masthead-tagline">Presented by Salinas Law Group LLC</div>
    </div>
    <div class="masthead-right">
      <div class="masthead-issue">District Trends &amp; Economic Indicators</div>
      <div class="masthead-credit">Updated Monthly &nbsp;·&nbsp; July 2026</div>
      <div class="masthead-credit">Tara Gaschler Salinas</div>
    </div>
  </div>
</div>

<div class="page">

  <div style="background:var(--green-deep);margin:-32px -32px 32px;padding:10px 32px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px">
    <span style="font-size:12px;color:var(--green-sage);font-family:var(--font-sans)">You are viewing <strong style="color:var(--cream)">District Trends &amp; Economic Indicators</strong></span>
    <a href="index.html" style="font-size:12px;font-weight:700;color:var(--gold);font-family:var(--font-sans);text-decoration:none;letter-spacing:.05em">← June 2026 Monthly Filing Report</a>
  </div>

  <!-- ABOUT THIS DATA -->
  <div class="sh" style="margin-top:0">
    <h2>Consumer Stress Indicators</h2>
    <span class="pill">NY Fed Consumer Credit Panel · Q1 2026</span>
  </div>

  <div class="ind-grid">
    <div class="ind-card alarm">
      <div class="ind-label">Credit Card Delinquency (90+ days)</div>
      <div class="ind-val">13.0%</div>
      <div class="ind-sub">Q1 2026 &nbsp;·&nbsp; % of balances 90+ days past due</div>
      <div class="ind-signal" style="color:#c0392b">▲ Highest since 2011 &nbsp;·&nbsp; Great Recession peak was 13.7%</div>
      <div class="ind-context">Was 7.5% pre-pandemic, 3.5% at 2021 trough. Has nearly quadrupled since 2021. Rising credit card stress leads Ch. 7 filings by 2–4 quarters. The surge is broad-based across income levels and geographies.</div>
      <div class="ind-source">NY Fed CCP/Equifax · HHDC Q1 2026</div>
    </div>
    <div class="ind-card alarm">
      <div class="ind-label">Auto Loan Delinquency (90+ days)</div>
      <div class="ind-val">5.6%</div>
      <div class="ind-sub">Q1 2026 &nbsp;·&nbsp; % of balances 90+ days past due</div>
      <div class="ind-signal" style="color:#c0392b">▲ Highest on record per NY Fed</div>
      <div class="ind-context">Was 4.5% pre-pandemic, 2.8% at 2021 trough. Driven by high vehicle prices and elevated loan balances since 2021. High auto delinquency is a strong Ch. 7 predictor, particularly for lower-income borrowers.</div>
      <div class="ind-source">NY Fed CCP/Equifax · HHDC Q1 2026</div>
    </div>
    <div class="ind-card watch">
      <div class="ind-label">Mortgage Delinquency (90+ days)</div>
      <div class="ind-val">1.7%</div>
      <div class="ind-sub">Q1 2026 &nbsp;·&nbsp; % of balances 90+ days past due</div>
      <div class="ind-signal" style="color:#e67e22">↑ Rising slowly from 0.9% low (2022)</div>
      <div class="ind-context">Near historically normal levels — far below Great Recession peak of ~10%. Deterioration is concentrated in lower-income areas and areas with declining home prices. Rising mortgage delinquency leads Ch. 13 filings as homeowners file to save their homes.</div>
      <div class="ind-source">NY Fed CCP/Equifax · HHDC Q1 2026</div>
    </div>
    <div class="ind-card crisis">
      <div class="ind-label">Student Loan Delinquency (90+ days)</div>
      <div class="ind-val">10.3%</div>
      <div class="ind-sub">Q1 2026 &nbsp;·&nbsp; % of balances 90+ days past due</div>
      <div class="ind-signal" style="color:#7B5EA7">⚠ ~9M borrowers in default ($220B)</div>
      <div class="ind-context">Reporting suppressed 2020–2024 during payment pause. Back to pre-pandemic levels (~11%) but with a second wave pending: 7 million SAVE plan borrowers exiting forbearance in H2 2026. Direct § 523(a)(8) discharge pipeline. Every 270 days of delinquency = default.</div>
      <div class="ind-source">NY Fed CCP/Equifax · HHDC Q1 2026 &amp; FSA Data Center Mar 2026</div>
    </div>
    <div class="ind-card normal" style="background:var(--green-deep)">
      <div class="ind-label" style="color:var(--green-sage)">D. Colo. June 2026</div>
      <div class="ind-val" style="color:var(--gold)">+28.2%</div>
      <div class="ind-sub" style="color:var(--green-sage)">vs. June 2025 &nbsp;·&nbsp; 927 total filings</div>
      <div class="ind-signal" style="color:var(--gold)">YTD: +21.8% vs H1 2025 &nbsp;·&nbsp; 4,975 filed</div>
      <div class="ind-context" style="color:var(--green-sage);border-top-color:rgba(138,168,143,0.3)">Ch. 13 up +50.9% vs Jun 2025. Pacing toward ~9,950 for full year — up from 8,549 in 2025. Surge driven by post-pandemic normalization + rising consumer debt stress.</div>
      <div class="ind-source" style="color:rgba(255,255,255,0.3)">CM/ECF D. Colo. · June 2026</div>
    </div>
  </div>

  <div style="background:var(--cream-warm);border:1px solid var(--gray-light);border-radius:4px;padding:10px 16px;margin-top:-4px;margin-bottom:16px">
    <span style="font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--green-sage)">About this data &nbsp;·&nbsp;</span><span style="font-size:11px;color:var(--gray-mid)">All rates from the <strong style="color:var(--charcoal)">NY Fed Consumer Credit Panel</strong> (Equifax, nationally representative) — serious delinquency 90+ days past due across <em>all</em> lenders, not just banks. The FRED bank-only series (2.92% credit cards) covers ~40% of the market and systematically undercounts stress because charge-offs exit the denominator. The NY Fed numbers reflect actual household financial distress.</span>
  </div>

  <!-- CHART SECTION -->
  <div class="sh">
    <h2>Delinquency vs. D. Colo. Filings</h2>
    <span class="pill">Select an indicator</span>
  </div>

  <div class="chart-selector-wrap">
    <label>Economic Indicator:</label>
    <select class="chart-select" id="chartSelect" onchange="selectChart(this.value)">
      <option value="cc">Credit Card Delinquency 90+ days — Ch. 7 leading indicator</option>
      <option value="auto">Auto Loan Delinquency 90+ days — Ch. 7 leading indicator</option>
      <option value="mtg">Mortgage Delinquency 90+ days — Ch. 13 leading indicator</option>
    </select>
  </div>

  <div class="chart-insight-panel">
    <div class="ci-title" id="insightTitle"></div>
    <div class="ci-body"  id="insightBody"></div>
    <div class="ci-source" id="insightSource"></div>
  </div>

  <div class="chart-canvas-wrap">
    <canvas id="mainChart" height="300" style="width:100%;display:block"></canvas>
    <div id="chartLegend" style="display:flex;gap:20px;margin-top:10px;flex-wrap:wrap;font-size:12px"></div>
    <p class="sup-note" id="suppNote" style="display:none">
      ⚠ Student loan delinquency data was suppressed during the federal payment pause (2020 Q2 – 2024 Q3).
      The gap reflects reporting suppression, not actual delinquency. Pre-pause baseline was ~11%.
    </p>
    <p class="source-note">Source: Federal Reserve Bank of New York, Quarterly Report on Household Debt and Credit (Consumer Credit Panel/Equifax). Annual averages of quarterly data. Covers all lenders, not just commercial banks.</p>
  </div>

  <!-- ANNUAL TOTALS TABLE -->
  <div class="sh">
    <h2>Annual Filing Totals</h2>
    <span class="pill">D. Colo. 2010 – 2026</span>
  </div>
  <div class="chart-wrap">
    <div style="overflow-x:auto">
    <table class="monthly-tbl">
      <thead><tr>
        <th>Year</th><th>Ch. 7</th><th>Ch. 13</th><th>Ch. 11</th><th>Ch. 12</th><th>Adversary</th><th>Total BK</th><th>YoY Δ</th>
      </tr></thead>
      <tbody id="annualTbody"></tbody>
    </table>
    </div>
  </div>

  <!-- YoY -->
  <div class="sh">
    <h2>Year-over-Year Comparison</h2>
    <span class="pill">June 2024 · 2025 · 2026</span>
  </div>
  <div class="mom-row" style="margin-bottom:16px">
    <div class="mom-card"><div class="mom-icon">📈</div><div>
      <div class="mom-label">Total Filings — June</div><div class="mom-val">+28.2%</div>
      <div class="mom-chg chg-up">vs. June 2025 &nbsp;·&nbsp; 927 filings</div>
      <div style="font-size:11px;color:var(--gray-mid)">Jun 2025: 723 (+10.6% vs Jun 2024) · Jun 2024: 654</div>
    </div></div>
    <div class="mom-card"><div class="mom-icon">7️⃣</div><div>
      <div class="mom-label">Chapter 7 — June</div><div class="mom-val">+16.4%</div>
      <div class="mom-chg chg-up">vs. June 2025 &nbsp;·&nbsp; 710 filings</div>
      <div style="font-size:11px;color:var(--gray-mid)">Jun 2025: 610 (+21.5% vs Jun 2024) · Jun 2024: 502</div>
    </div></div>
    <div class="mom-card"><div class="mom-icon">🔢</div><div>
      <div class="mom-label">Chapter 13 — June</div><div class="mom-val">+50.9%</div>
      <div class="mom-chg chg-up">vs. June 2025 &nbsp;·&nbsp; 166 filings</div>
      <div style="font-size:11px;color:var(--gray-mid)">Jun 2025: 110 (−19.7% vs Jun 2024) · Jun 2024: 137</div>
    </div></div>
    <div class="mom-card"><div class="mom-icon">📋</div><div>
      <div class="mom-label">H1 Total (Jan–Jun)</div><div class="mom-val">+21.8%</div>
      <div class="mom-chg chg-up">vs. H1 2025 &nbsp;·&nbsp; 4,975 filed</div>
      <div style="font-size:11px;color:var(--gray-mid)">H1 2025: 4,084 (+10.4% vs H1 2024) · H1 2024: 3,699</div>
    </div></div>
    <div class="mom-card"><div class="mom-icon">⚡</div><div>
      <div class="mom-label">2026 Full-Year Pace</div><div class="mom-val">+16.4%</div>
      <div class="mom-chg chg-up">above 2025 full year (projected)</div>
      <div style="font-size:11px;color:var(--gray-mid)">~9,950 projected · 2025: 8,549 · 2024: 7,690</div>
    </div></div>
  </div>

  <!-- FILING COMPARISON CHART -->
  <div class="sh"><h2>2026 Monthly Filing Trend vs. Prior Years</h2><span class="pill">% Difference · Select comparison year</span></div>
