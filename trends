// ── Annual totals table ───────────────────────────────────────────────────
(function buildAnnualTable() {
  const years = Object.keys(ALL_YEARS).map(Number).sort((a,b)=>a-b);
  const tbody = document.getElementById('annualTbody');
  if (!tbody) return;
  // Build a lookup of H1 totals for H1 vs H1 comparison
  const h1Totals = {};
  years.forEach(yr => {
    h1Totals[yr] = ALL_YEARS[yr].total.slice(0,6).reduce((s,v)=>s+(v||0),0);
  });
  let rows='';
  // Display descending (2026 at top)
  years.slice().reverse().forEach(yr => {
    const d=ALL_YEARS[yr];
    const tot=d.total.reduce((s,v)=>s+(v||0),0);
    const c7 =d.ch7.reduce((s,v)=>s+(v||0),0);
    const c13=d.ch13.reduce((s,v)=>s+(v||0),0);
    const c11=d.ch11.reduce((s,v)=>s+(v||0),0);
    const c12=d.ch12.reduce((s,v)=>s+(v||0),0);
    const ap =d.ap.reduce((s,v)=>s+(v||0),0);
    const isH1=d.total.some(v=>v===null);
    const note=isH1?' <span style="font-size:10px;color:var(--green-sage)">(H1)</span>':'';
    let yoy='—';
    if (ALL_YEARS[yr-1]) {
      if (isH1) {
        const priorH1 = h1Totals[yr-1];
        if (priorH1) {
          const pct=((tot-priorH1)/priorH1*100).toFixed(1);
          const cls=tot>=priorH1?'chg-up':'chg-dn';
          yoy=`<span class="${cls}">${tot>=priorH1?'+':''}${pct}% vs H1 ${yr-1}</span>`;
        }
      } else {
        const priorTot=ALL_YEARS[yr-1].total.reduce((s,v)=>s+(v||0),0);
        const pct=((tot-priorTot)/priorTot*100).toFixed(1);
        const cls=tot>=priorTot?'chg-up':'chg-dn';
        yoy=`<span class="${cls}">${tot>=priorTot?'+':''}${pct}%</span>`;
      }
    }
    const hl=yr===2026?'style="background:rgba(214,174,71,0.06);font-weight:700"':'';
    rows+=`<tr ${hl}><td>${yr}${note}</td><td>${c7.toLocaleString()}</td><td>${c13.toLocaleString()}</td><td>${c11}</td><td>${c12}</td><td>${ap}</td><td>${tot.toLocaleString()}</td><td>${yoy}</td></tr>`;
  });
  tbody.innerHTML=rows;
})();

