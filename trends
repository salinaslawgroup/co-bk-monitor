const DELINQ_DATA = { cc:CC_AVGS, auto:AUTO_AVGS, mtg:MTG_AVGS, sl:SL_AVGS };

function drawMainChart() {
  const canvas=document.getElementById('mainChart');
  if (!canvas) return;
  const key=currentChart;
  const cfg=CHART_CONFIG[key];
  const odata=DELINQ_DATA[key];
  const W=canvas.parentElement.offsetWidth||860;
  canvas.width=W; canvas.height=300;
  const ctx=canvas.getContext('2d');
  ctx.clearRect(0,0,W,300);

  const years=Object.keys(ALL_YEARS).map(Number).sort((a,b)=>a-b);
  const PAD={l:64,r:64,t:24,b:48};
  const cW=W-PAD.l-PAD.r, cH=300-PAD.t-PAD.b;

  const filingVals=years.map(yr=>{
    const d=ALL_YEARS[yr];
    if (cfg.filingKey==='ch7')  return d.ch7.reduce((s,v)=>s+(v||0),0);
    if (cfg.filingKey==='ch13') return d.ch13.reduce((s,v)=>s+(v||0),0);
    return d.total.reduce((s,v)=>s+(v||0),0);
  });

  const maxFiling = cfg.filingKey==='ch13' ? 6000 : cfg.filingKey==='ch7' ? 32000 : 36000;
  const maxRate   = cfg.maxRate;
  const toLeft =v=>PAD.t+cH-(v/maxFiling)*cH;
  const toRight=v=>PAD.t+cH-(v/maxRate)*cH;
  const xPos   =i=>PAD.l+(i/(years.length-1))*cW;

  // Grid
  ctx.strokeStyle='#e8e5de'; ctx.lineWidth=1;
  for (let i=0;i<=5;i++) {
    const y=PAD.t+(cH/5)*i;
    ctx.beginPath(); ctx.moveTo(PAD.l,y); ctx.lineTo(W-PAD.r,y); ctx.stroke();
    ctx.fillStyle='#254E38'; ctx.font='10px sans-serif'; ctx.textAlign='right';
    const lv=Math.round(maxFiling*(1-i/5));
    ctx.fillText(lv>=1000?(lv/1000).toFixed(0)+'k':lv, PAD.l-5,y+4);
    ctx.fillStyle=cfg.color; ctx.textAlign='left';
    ctx.fillText((maxRate*(1-i/5)).toFixed(1)+'%',W-PAD.r+5,y+4);
  }

  // Filing bars
  const barW=Math.max(5,Math.floor(cW/years.length)-3);
  years.forEach((yr,i)=>{
    const h=PAD.t+cH-toLeft(filingVals[i]);
    ctx.fillStyle='rgba(37,78,56,0.13)';
    ctx.fillRect(xPos(i)-barW/2, toLeft(filingVals[i]), barW, h);
  });

  // Delinquency line — handle gaps for student loans
  const segments=[[]];
  years.forEach((yr,i)=>{
    const v=odata[String(yr)];
    if (v===null||v===undefined) { segments.push([]); }
    else { segments[segments.length-1].push({i,v}); }
  });

  segments.filter(s=>s.length>0).forEach(seg=>{
    ctx.beginPath(); ctx.strokeStyle=cfg.color; ctx.lineWidth=2.5; ctx.lineJoin='round';
    seg.forEach((pt,j)=>{
      j===0?ctx.moveTo(xPos(pt.i),toRight(pt.v)):ctx.lineTo(xPos(pt.i),toRight(pt.v));
    });
    ctx.stroke();
    seg.forEach(pt=>{
      ctx.beginPath(); ctx.arc(xPos(pt.i),toRight(pt.v),3,0,Math.PI*2);
      ctx.fillStyle=cfg.color; ctx.fill();
    });
  });

  // SL gap annotation
  if (cfg.isSL) {
    const i2020=years.indexOf(2020), i2024=years.indexOf(2024);
    if (i2020>=0&&i2024>=0) {
      const gx=xPos(i2020)+barW, gw=xPos(i2024)-barW-gx;
      if (gw>0) {
        ctx.fillStyle='rgba(123,94,167,0.07)'; ctx.fillRect(gx,PAD.t,gw,cH);
        ctx.fillStyle='rgba(123,94,167,0.45)'; ctx.font='bold 10px sans-serif'; ctx.textAlign='center';
        ctx.fillText('Payment Pause',(gx+gx+gw)/2,PAD.t+cH/2-8);
        ctx.font='10px sans-serif';
        ctx.fillText('(Reporting Suppressed)',(gx+gx+gw)/2,PAD.t+cH/2+8);
      }
    }
  }

  // X labels
  ctx.fillStyle='#3E403E'; ctx.font='10px sans-serif'; ctx.textAlign='center';
  years.forEach((yr,i)=>{ if(yr%2===0||yr===2026||yr===2013) ctx.fillText(yr,xPos(i),PAD.t+cH+16); });

  // Legend
  document.getElementById('chartLegend').innerHTML=`
    <span style="display:flex;align-items:center;gap:5px">
      <span style="width:16px;height:12px;background:rgba(37,78,56,0.13);display:inline-block;border-radius:2px"></span>
      ${cfg.filingLabel} (left axis)
    </span>
    <span style="display:flex;align-items:center;gap:5px">
      <span style="width:20px;height:3px;background:${cfg.color};display:inline-block"></span>
      Serious Delinquency Rate 90+ days % (right axis) — NY Fed CCP
    </span>`;
}

// ── Comparison chart ─────────────────────────────────────────────────────────
const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const DATA_2026 = ALL_YEARS['2026'].total; // [648,631,927,982,860,927,null,...]

function drawCompChart() {
  const canvas = document.getElementById('compChart');
  if (!canvas) return;
  const compYr = parseInt(document.getElementById('compYearSelect').value);
  const compData = ALL_YEARS[String(compYr)].total;
  const W = canvas.parentElement.offsetWidth || 860;
  canvas.width = W; canvas.height = 260;
  const ctx = canvas.getContext('2d');
  ctx.clearRect(0,0,W,260);

  // Only Jan-Jun 2026 available
  const availMonths = DATA_2026.map((v,i) => v !== null ? i : -1).filter(i => i >= 0);
  const n = availMonths.length; // 6
  const PAD = {l:52, r:20, t:24, b:48};
  const cW = W - PAD.l - PAD.r;
  const cH = 260 - PAD.t - PAD.b;
  const barW = Math.max(24, Math.floor(cW / n) - 10);
  const gap = (cW - barW * n) / (n + 1);

  // Compute pct diffs
  const diffs = availMonths.map(i => {
    const v26 = DATA_2026[i];
    const vPr = compData[i];
    if (!v26 || !vPr) return null;
    return ((v26 - vPr) / vPr * 100);
  });

  const maxAbs = Math.max(60, ...diffs.filter(Boolean).map(Math.abs));
  const zeroY = PAD.t + cH / 2;

  // Grid lines
  [-60,-40,-20,0,20,40,60].forEach(pct => {
    if (Math.abs(pct) > maxAbs + 5) return;
    const y = zeroY - (pct / maxAbs) * (cH / 2);
    ctx.strokeStyle = pct === 0 ? '#888' : '#e8e5de';
    ctx.lineWidth = pct === 0 ? 1.5 : 1;
    ctx.beginPath(); ctx.moveTo(PAD.l, y); ctx.lineTo(W - PAD.r, y); ctx.stroke();
    ctx.fillStyle = '#9a9a98'; ctx.font = '10px sans-serif'; ctx.textAlign = 'right';
    ctx.fillText((pct > 0 ? '+' : '') + pct + '%', PAD.l - 4, y + 4);
  });

  // Bars + labels
  availMonths.forEach((mi, i) => {
    const pct = diffs[i];
    if (pct === null) return;
    const x = PAD.l + gap + i * (barW + gap);
    const barH = Math.abs(pct) / maxAbs * (cH / 2);
    const isUp = pct >= 0;
    ctx.fillStyle = isUp ? 'rgba(37,78,56,0.22)' : 'rgba(192,57,43,0.22)';
    ctx.fillRect(x, isUp ? zeroY - barH : zeroY, barW, barH);
    ctx.strokeStyle = isUp ? '#254E38' : '#c0392b';
    ctx.lineWidth = 1.5;
    ctx.strokeRect(x, isUp ? zeroY - barH : zeroY, barW, barH);

    // Pct label above/below bar
    ctx.fillStyle = isUp ? '#254E38' : '#c0392b';
    ctx.font = 'bold 11px sans-serif'; ctx.textAlign = 'center';
    const labelY = isUp ? zeroY - barH - 5 : zeroY + barH + 13;
    ctx.fillText((pct > 0 ? '+' : '') + pct.toFixed(1) + '%', x + barW/2, labelY);

    // 2026 value below
    ctx.fillStyle = '#D6AE47'; ctx.font = '10px sans-serif';
    ctx.fillText(DATA_2026[mi].toLocaleString(), x + barW/2, PAD.t + cH + 16);

    // Month label
    ctx.fillStyle = '#3E403E'; ctx.font = '11px sans-serif';
    ctx.fillText(MONTHS[mi], x + barW/2, PAD.t + cH + 30);
  });

  // Subtitle
  const totalDiff = availMonths.reduce((s,i) => s + (DATA_2026[i]||0), 0);
  const totalComp = availMonths.reduce((s,i) => s + (compData[i]||0), 0);
  const overallPct = ((totalDiff - totalComp) / totalComp * 100).toFixed(1);
  const sub = document.getElementById('compSubtitle');
  if (sub) sub.textContent = `H1 total: 4,975 vs ${totalComp.toLocaleString()} in ${compYr} (${overallPct > 0 ? '+' : ''}${overallPct}% overall)`;
}

window.addEventListener('resize', () => { drawMainChart(); drawCompChart(); });
setTimeout(() => { selectChart('cc'); drawCompChart(); }, 100);
</script>
